{
    "name": "app",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test:unit": "vitest run --passWithNoTests",
        "test:unit:watch": "vitest",
        "test:unit:coverage": "vitest run --coverage",
        "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
        "test:integration:watch": "vitest --config vitest.integration.config.ts",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "db:seed": "tsx src/db/seed.ts",
        "tg:setup-menu": "tsx scripts/setup-telegram-menu.ts",
        "check:env-audit": "tsx scripts/check-env-audit.ts",
        "check:cron-routes": "tsx scripts/check-cron-routes.ts",
        "check:env-schema": "tsx scripts/check-env-schema.ts",
        "check:all": "tsx scripts/check-env-audit.ts && tsx scripts/check-cron-routes.ts",
        "prepare": "husky"
    },
    "dependencies": {
        "@auth/drizzle-adapter": "^1.11.2",
        "@aws-sdk/client-s3": "^3.1045.0",
        "@aws-sdk/s3-request-presigner": "^3.1045.0",
        "@hookform/resolvers": "^5.2.2",
        "@node-rs/argon2": "^2.0.2",
        "@react-email/components": "^1.0.12",
        "@react-email/render": "^2.0.8",
        "@react-spring/three": "^10.0.3",
        "@react-three/drei": "^10.7.7",
        "@react-three/fiber": "^9.6.0",
        "@react-three/postprocessing": "^3.0.4",
        "@upstash/ratelimit": "^2.0.5",
        "@upstash/redis": "^1.34.3",
        "bullmq": "^5.74.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "drizzle-orm": "^0.45.2",
        "embla-carousel-react": "^8.6.0",
        "framer-motion": "^12.38.0",
        "grammy": "^1.42.0",
        "ioredis": "^5.10.1",
        "lucide-react": "^1.8.0",
        "meshoptimizer": "^1.1.1",
        "next": "16.2.3",
        "next-auth": "5.0.0-beta.31",
        "next-themes": "^0.4.6",
        "nuqs": "^2.8.9",
        "otplib": "^13.4.0",
        "postgres": "^3.4.9",
        "posthog-js": "^1.369.1",
        "posthog-node": "^5.34.1",
        "postprocessing": "^6.39.1",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-hook-form": "^7.72.1",
        "resend": "^6.12.0",
        "sonner": "^2.0.7",
        "three": "^0.183.2",
        "three-stdlib": "^2.36.1",
        "zod": "^4.3.6",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@axe-core/playwright": "4.10.1",
        "@playwright/test": "^1.52.0",
        "@tailwindcss/postcss": "^4.1.7",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.5.2",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^4.4.1",
        "@vitest/coverage-v8": "^3.1.4",
        "babel-plugin-react-compiler": "1.0.0",
        "dotenv": "^16.4.5",
        "drizzle-kit": "^0.31.0",
        "eslint": "^9",
        "eslint-config-next": "16.2.3",
        "fast-check": "^4.8.0",
        "husky": "^9.1.7",
        "jsdom": "^25.0.1",
        "lint-staged": "^15.5.0",
        "prettier": "^3.5.3",
        "server-only": "^0.0.1",
        "tailwindcss": "^4.1.7",
        "tsx": "^4.19.2",
        "typescript": "^5",
        "vitest": "^3.1.4"
    },
    "lint-staged": {
        "*.{ts,tsx,mts}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yaml,yml}": [
            "prettier --write"
        ],
        "*.css": [
            "prettier --write"
        ]
    }
}
